{
  "name": "kupukupu",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "electron:dev": "cross-env NODE_ENV=development PORT=3001 concurrently \"vite\" \"electron .\"",
    "electron:build": "cross-env NODE_ENV=production vite build && electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint \"**/*.{js,cjs,mjs}\"",
    "lint:fix": "eslint \"**/*.{js,cjs,mjs}\" --fix",
    "format:all": "prettier --write \"**/*.{js,cjs,mjs,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,cjs,mjs,css,html,json,md}\"",
    "format:diff": "bash -c 'diff \"$1\" <(npx prettier \"$1\")' --",
    "validate": "npm run lint && npm run format:check && npm run test && npm run test:e2e"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "axe-core": "^4.10.2",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.10.0",
    "eslint-plugin-jsdoc": "^50.6.1",
    "eslint-plugin-playwright": "^2.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-playwright-preset": "^4.0.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "vite": "^6.0.5",
    "vite-plugin-eslint": "^1.8.1"
  }
}
